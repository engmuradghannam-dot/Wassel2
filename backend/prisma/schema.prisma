// MuradERP Database Schema
// Proprietary - All Rights Reserved © 2026 Murad Ghannam

generator client {
  provider   = "prisma-client-js"
  engineType = "binary"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ============================================
// CORE - Users & Authentication
// ============================================

model User {
  id            String    @id @default(uuid())
  email         String    @unique
  password      String
  firstName     String
  lastName      String
  phone         String?
  avatar        String?
  role          UserRole  @default(USER)
  status        UserStatus @default(ACTIVE)
  emailVerified Boolean   @default(false)
  lastLoginAt   DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  deletedAt     DateTime?

  // Relations
  sessions      Session[]
  auditLogs     AuditLog[]
  notifications Notification[]
  uploadedFiles FileAttachment[]
  zakatCalculations ZakatCalculation[]
  dataImportLogs DataImportLog[]
  mrpRuns       MRPRun[]

  // Employee relation
  employee      Employee?

  // Created records
  createdCompanies    Company[]    @relation("CompanyCreatedBy")
  createdCustomers    Customer[]   @relation("CustomerCreatedBy")
  createdSuppliers    Supplier[]   @relation("SupplierCreatedBy")
  createdItems        Item[]       @relation("ItemCreatedBy")
  createdInvoices     Invoice[]    @relation("InvoiceCreatedBy")
  createdJournalEntries JournalEntry[] @relation("JournalEntryCreatedBy")
  createdProjects     Project[]    @relation("ProjectCreatedBy")
  createdTasks        Task[]       @relation("TaskCreatedBy")
  createdLeads        Lead[]       @relation("LeadCreatedBy")
  assignedLeads       Lead[]       @relation("LeadAssignedTo")
  createdOpportunities Opportunity[] @relation("OpportunityCreatedBy")
  assignedOpportunities Opportunity[] @relation("OpportunityAssignedTo")
  createdAssets       Asset[]      @relation("AssetCreatedBy")
  createdSalesOrders  SalesOrder[] @relation("SalesOrderCreatedBy")
  createdPurchaseOrders PurchaseOrder[] @relation("PurchaseOrderCreatedBy")
  createdStockEntries StockEntry[] @relation("StockEntryCreatedBy")
  createdQuotations   Quotation[]  @relation("QuotationCreatedBy")
  createdDeliveryNotes DeliveryNote[] @relation("DeliveryNoteCreatedBy")
  createdRfqs         RequestForQuotation[] @relation("RfqCreatedBy")
  createdPurchaseReceipts PurchaseReceipt[] @relation("PurchaseReceiptCreatedBy")
  createdStockReconciliations StockReconciliation[] @relation("StockReconciliationCreatedBy")
  createdBoms  BOM[] @relation("BOMCreatedBy")
  createdWorkOrders WorkOrder[] @relation("WorkOrderCreatedBy")
  createdQualityInspections QualityInspection[] @relation("QICreatedBy")
  createdIssues Issue[] @relation("IssueCreatedBy")
  assignedTodos Todo[]
  companyMemberships CompanyMember[]

  @@map("users")
}

model Session {
  id        String   @id @default(uuid())
  token     String   @unique
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  expiresAt DateTime
  createdAt DateTime @default(now())
  ipAddress String?
  userAgent String?

  @@map("sessions")
}

// Explicit membership table: which users can access which companies, and
// with what role inside that company. This is the single source of truth
// used to validate every companyId a request touches — a user may belong to
// more than one company, but only the ones listed here.
model CompanyMember {
  id        String   @id @default(uuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  companyId String
  company   Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  role      UserRole @default(USER)
  createdAt DateTime @default(now())

  @@unique([userId, companyId])
  @@map("company_members")
}

enum UserRole {
  SUPER_ADMIN
  ADMIN
  MANAGER
  ACCOUNTANT
  SALES
  PURCHASE
  INVENTORY
  HR
  USER
}

enum UserStatus {
  ACTIVE
  INACTIVE
  SUSPENDED
  PENDING
}

// ============================================
// CORE - Company & Branches
// ============================================

model Company {
  id          String   @id @default(uuid())
  name        String
  nameAr      String?
  legalName   String?
  taxId       String?
  commercialReg String?
  email       String?
  phone       String?
  website     String?
  logo        String?

  // Address
  address     String?
  city        String?
  state       String?
  country     String   @default("SA")
  zipCode     String?
  latitude    Float?
  longitude   Float?

  // Settings
  currency    String   @default("SAR")
  fiscalYearStart Int @default(1)
  fiscalYearEnd   Int @default(12)

  status      CompanyStatus @default(ACTIVE)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  createdById String
  createdBy   User     @relation("CompanyCreatedBy", fields: [createdById], references: [id])

  // Consolidation - group company hierarchy
  parentCompanyId String?
  parentCompany   Company? @relation("CompanyGroup", fields: [parentCompanyId], references: [id])
  subsidiaries    Company[] @relation("CompanyGroup")

  // Relations
  branches    Branch[]
  warehouses  Warehouse[]
  accounts    Account[]
  customers   Customer[]
  suppliers   Supplier[]
  items       Item[]
  employees   Employee[]
  projects    Project[]
  journalEntries JournalEntry[]
  invoices    Invoice[]
  leads        Lead[]
  opportunities Opportunity[]
  assets       Asset[]
  salesOrders  SalesOrder[]
  purchaseOrders PurchaseOrder[]
  stockEntries StockEntry[]
  quotations   Quotation[]
  deliveryNotes DeliveryNote[]
  rfqs         RequestForQuotation[]
  purchaseReceipts PurchaseReceipt[]
  stockReconciliations StockReconciliation[]
  posProfiles  POSProfile[]
  loyaltyPrograms LoyaltyProgram[]
  boms         BOM[]
  workOrders   WorkOrder[]
  productionPlans ProductionPlan[]
  subcontractingOrders SubcontractingOrder[]
  qualityInspections QualityInspection[]
  qualityGoals QualityGoal[]
  jobOpenings  JobOpening[]
  issues       Issue[]
  maintenanceSchedules MaintenanceSchedule[]
  webPages     WebPage[]
  blogPosts    BlogPost[]
  workflows    Workflow[]
  printFormats PrintFormat[]
  customReports CustomReport[]
  members      CompanyMember[]
  auditLogs    AuditLog[]
  fileAttachments FileAttachment[]
  systemSettings SystemSetting[]
  zakatCalculations ZakatCalculation[]
  dataImportLogs DataImportLog[]
  contacts     Contact[]
  bankDetails  BankDetail[] @relation("CompanyBankDetails")
  ownBankDetails BankDetail[] @relation("CompanyOwnBankDetails")
  partnerFunctions PartnerFunction[]
  mrpRuns      MRPRun[]
  plannedOrders PlannedOrder[]
  batches      Batch[]
  serialNumbers SerialNumber[]
  priceLists   PriceList[]
  costCenters  CostCenter[]
  salesForecasts SalesForecast[]
  iotDevices   IoTDevice[]

  @@map("companies")
}

enum CompanyStatus {
  ACTIVE
  INACTIVE
}

model Branch {
  id        String   @id @default(uuid())
  name      String
  nameAr    String?
  code      String

  // Address
  address   String?
  city      String?
  state     String?
  country   String   @default("SA")
  zipCode   String?
  latitude  Float?
  longitude Float?

  phone     String?
  email     String?
  managerId String?

  status    BranchStatus @default(ACTIVE)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  companyId String
  company   Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)

  // Relations
  warehouses Warehouse[]
  employees  Employee[]
  posProfiles POSProfile[]

  @@unique([companyId, code])
  @@map("branches")
}

enum BranchStatus {
  ACTIVE
  INACTIVE
}

// ============================================
// CORE - Warehouses
// ============================================

model Warehouse {
  id            String   @id @default(uuid())
  name          String
  nameAr        String?
  code          String

  // Location
  address       String?
  city          String?
  state         String?
  country       String   @default("SA")
  latitude      Float?
  longitude     Float?

  // Inventory Settings
  isDefault     Boolean  @default(false)
  allowNegative Boolean  @default(false)

  status        WarehouseStatus @default(ACTIVE)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  companyId     String
  company       Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  branchId      String?
  branch        Branch?  @relation(fields: [branchId], references: [id])

  // Relations
  stockEntries  StockEntry[]
  stockLedgers  StockLedger[]
  binCards      BinCard[]
  deliveryNotes DeliveryNote[]
  purchaseReceipts PurchaseReceipt[]
  stockReconciliations StockReconciliation[]
  posProfiles   POSProfile[]
  batches       Batch[]
  serialNumbers SerialNumber[]
  iotDevices    IoTDevice[]

  @@unique([companyId, code])
  @@map("warehouses")
}

enum WarehouseStatus {
  ACTIVE
  INACTIVE
}

// ============================================
// ACCOUNTING - Chart of Accounts
// ============================================

model Account {
  id          String      @id @default(uuid())
  code        String
  name        String
  nameAr      String?

  // Account Type
  type        AccountType
  accountType AccountCategory

  // Hierarchy
  parentId    String?
  parent      Account?    @relation("AccountHierarchy", fields: [parentId], references: [id])
  children    Account[]   @relation("AccountHierarchy")

  // Balance
  openingBalance Decimal @default(0) @db.Decimal(18, 2)
  currentBalance Decimal @default(0) @db.Decimal(18, 2)

  // Settings
  isGroup     Boolean     @default(false)
  isBank      Boolean     @default(false)
  bankAccount String?
  bankName    String?
  currency    String      @default("SAR")

  status      AccountStatus @default(ACTIVE)
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt

  companyId   String
  company     Company     @relation(fields: [companyId], references: [id], onDelete: Cascade)

  // Relations
  debitEntries  JournalEntryLine[] @relation("DebitAccount")
  creditEntries JournalEntryLine[] @relation("CreditAccount")

  @@unique([companyId, code])
  @@map("accounts")
}

enum AccountType {
  ASSET
  LIABILITY
  EQUITY
  INCOME
  EXPENSE
}

enum AccountCategory {
  // Assets
  CURRENT_ASSET
  FIXED_ASSET
  INTANGIBLE_ASSET
  // Liabilities
  CURRENT_LIABILITY
  LONG_TERM_LIABILITY
  // Equity
  CAPITAL
  RETAINED_EARNINGS
  // Income
  OPERATING_INCOME
  OTHER_INCOME
  // Expense
  COST_OF_GOODS_SOLD
  OPERATING_EXPENSE
  ADMIN_EXPENSE
  SELLING_EXPENSE
  OTHER_EXPENSE
}

enum AccountStatus {
  ACTIVE
  INACTIVE
}

// ============================================
// ACCOUNTING - Journal Entries
// ============================================

model JournalEntry {
  id          String   @id @default(uuid())
  entryNumber String
  entryDate   DateTime
  reference   String?
  description String?
  notes       String?

  // Totals
  totalDebit  Decimal  @db.Decimal(18, 2)
  totalCredit Decimal  @db.Decimal(18, 2)

  // Status
  status      JournalStatus @default(DRAFT)
  postedAt    DateTime?
  postedById  String?

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  companyId   String
  company     Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  createdById String
  createdBy   User     @relation("JournalEntryCreatedBy", fields: [createdById], references: [id])

  // Relations
  lines       JournalEntryLine[]

  @@unique([companyId, entryNumber])

  @@map("journal_entries")
}

model JournalEntryLine {
  id          String   @id @default(uuid())

  debitAccountId  String?
  debitAccount    Account? @relation("DebitAccount", fields: [debitAccountId], references: [id])

  creditAccountId String?
  creditAccount   Account? @relation("CreditAccount", fields: [creditAccountId], references: [id])

  amount      Decimal  @db.Decimal(18, 2)
  description String?

  costCenterId String?
  costCenter   CostCenter? @relation(fields: [costCenterId], references: [id])

  journalEntryId String
  journalEntry   JournalEntry @relation(fields: [journalEntryId], references: [id], onDelete: Cascade)

  @@map("journal_entry_lines")
}

enum JournalStatus {
  DRAFT
  POSTED
  CANCELLED
}

// ============================================
// SALES - Customers
// ============================================

model Customer {
  id          String   @id @default(uuid())
  code        String
  name        String
  nameAr      String?

  // Contact
  email       String?
  phone       String?
  mobile      String?
  fax         String?
  website     String?

  // Address
  address     String?
  city        String?
  state       String?
  country     String   @default("SA")
  zipCode     String?
  latitude    Float?
  longitude   Float?

  // Tax
  taxId       String?
  commercialReg String?

  // Financial
  creditLimit     Decimal  @default(0) @db.Decimal(18, 2)
  currentBalance  Decimal  @default(0) @db.Decimal(18, 2)
  paymentTerms    Int      @default(30) // days
  currency        String   @default("SAR")

  // Classification
  customerType    CustomerType @default(INDIVIDUAL)
  customerGroup   String?

  status      CustomerStatus @default(ACTIVE)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  companyId   String
  company     Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  createdById String
  createdBy   User     @relation("CustomerCreatedBy", fields: [createdById], references: [id])

  // Relations
  invoices    Invoice[]
  salesOrders SalesOrder[]
  opportunities Opportunity[]
  convertedFromLead Lead?
  quotations  Quotation[]
  deliveryNotes DeliveryNote[]
  loyaltyPoints LoyaltyPoint[]
  contacts    Contact[]
  bankDetails BankDetail[]
  partnerFunctions PartnerFunction[]

  @@unique([companyId, code])

  @@map("customers")
}

enum CustomerType {
  INDIVIDUAL
  COMPANY
  GOVERNMENT
}

enum CustomerStatus {
  ACTIVE
  INACTIVE
  BLOCKED
}

// ============================================
// PURCHASE - Suppliers
// ============================================

model Supplier {
  id          String   @id @default(uuid())
  code        String
  name        String
  nameAr      String?

  // Contact
  email       String?
  phone       String?
  mobile      String?
  fax         String?
  website     String?

  // Address
  address     String?
  city        String?
  state       String?
  country     String   @default("SA")
  zipCode     String?
  latitude    Float?
  longitude   Float?

  // Tax
  taxId       String?
  commercialReg String?

  // Financial
  creditLimit     Decimal  @default(0) @db.Decimal(18, 2)
  currentBalance  Decimal  @default(0) @db.Decimal(18, 2)
  paymentTerms    Int      @default(30)
  currency        String   @default("SAR")

  // Classification
  supplierType    SupplierType @default(COMPANY)
  supplierGroup   String?

  status      SupplierStatus @default(ACTIVE)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  companyId   String
  company     Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  createdById String
  createdBy   User     @relation("SupplierCreatedBy", fields: [createdById], references: [id])

  // Relations
  purchaseOrders PurchaseOrder[]
  purchaseInvoices Invoice[]
  rfqs        RequestForQuotation[]
  purchaseReceipts PurchaseReceipt[]
  contacts    Contact[]
  bankDetails BankDetail[]
  partnerFunctions PartnerFunction[]

  @@unique([companyId, code])

  @@map("suppliers")
}

enum SupplierType {
  COMPANY
  INDIVIDUAL
  IMPORTER
}

enum SupplierStatus {
  ACTIVE
  INACTIVE
  BLOCKED
}

// ============================================
// INVENTORY - Items
// ============================================

model Item {
  id          String   @id @default(uuid())
  code        String
  name        String
  nameAr      String?
  description String?

  // Classification
  itemType    ItemType @default(INVENTORY)
  itemGroup   String?
  brand       String?

  // Unit
  unitOfMeasure String @default("PCS")

  // Pricing
  standardCost    Decimal @default(0) @db.Decimal(18, 2)
  sellingPrice    Decimal @default(0) @db.Decimal(18, 2)

  // Inventory
  isStockItem     Boolean @default(true)
  hasVariants     Boolean @default(false)

  // Reorder
  reorderLevel    Decimal @default(0) @db.Decimal(18, 2)
  reorderQuantity Decimal @default(0) @db.Decimal(18, 2)

  // Tax
  taxRate         Decimal @default(15) @db.Decimal(5, 2)

  status      ItemStatus @default(ACTIVE)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  companyId   String
  company     Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  createdById String
  createdBy   User     @relation("ItemCreatedBy", fields: [createdById], references: [id])

  // Relations
  stockLedgers  StockLedger[]
  binCards      BinCard[]
  invoiceItems  InvoiceItem[]
  orderItems    OrderItem[]
  stockEntryItems StockEntryItem[]
  quotationItems QuotationItem[]
  deliveryNoteItems DeliveryNoteItem[]
  rfqItems      RfqItem[]
  purchaseReceiptItems PurchaseReceiptItem[]
  boms          BOM[]
  bomRawMaterials BOMRawMaterial[]
  qualityInspections QualityInspection[]
  stockReconciliationItems StockReconciliationItem[]
  mrpExceptions MRPException[]
  plannedOrders PlannedOrder[]
  batches       Batch[]
  serialNumbers SerialNumber[]
  uomConversions UOMConversion[]
  priceListItems PriceListItem[]
  salesForecasts SalesForecast[]

  @@unique([companyId, code])

  @@map("items")
}

enum ItemType {
  INVENTORY
  NON_INVENTORY
  SERVICE
  ASSET
  RAW_MATERIAL
  FINISHED_GOOD
}

enum ItemStatus {
  ACTIVE
  INACTIVE
  DISCONTINUED
}

// ============================================
// INVENTORY - Stock Management
// ============================================

model StockEntry {
  id          String   @id @default(uuid())
  entryNumber String
  entryDate   DateTime
  entryType   StockEntryType
  reference   String?
  description String?

  status      StockEntryStatus @default(DRAFT)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  companyId   String
  company     Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  createdById String
  createdBy   User     @relation("StockEntryCreatedBy", fields: [createdById], references: [id])

  warehouseId String
  warehouse   Warehouse @relation(fields: [warehouseId], references: [id])

  // Relations
  items       StockEntryItem[]

  @@unique([companyId, entryNumber])

  @@map("stock_entries")
}

model StockEntryItem {
  id          String   @id @default(uuid())
  itemId      String
  item        Item     @relation(fields: [itemId], references: [id])

  quantity    Decimal  @db.Decimal(18, 4)
  unitCost    Decimal  @db.Decimal(18, 4)
  totalCost   Decimal  @db.Decimal(18, 2)

  batchNo     String?
  batchId     String?
  batch       Batch?   @relation(fields: [batchId], references: [id])
  expiryDate  DateTime?

  stockEntryId String
  stockEntry   StockEntry @relation(fields: [stockEntryId], references: [id], onDelete: Cascade)

  @@map("stock_entry_items")
}

enum StockEntryType {
  RECEIPT
  ISSUE
  TRANSFER
  ADJUSTMENT
  RETURN
  MANUFACTURE
}

enum StockEntryStatus {
  DRAFT
  SUBMITTED
  CANCELLED
}

model StockLedger {
  id          String   @id @default(uuid())
  entryDate   DateTime

  itemId      String
  item        Item     @relation(fields: [itemId], references: [id])

  warehouseId String
  warehouse   Warehouse @relation(fields: [warehouseId], references: [id])

  entryType   StockEntryType
  quantity    Decimal  @db.Decimal(18, 4)
  unitCost    Decimal  @db.Decimal(18, 4)
  totalCost   Decimal  @db.Decimal(18, 2)

  balanceQty  Decimal  @db.Decimal(18, 4)
  balanceValue Decimal @db.Decimal(18, 2)

  reference   String?

  createdAt   DateTime @default(now())

  @@map("stock_ledger")
}

model BinCard {
  id          String   @id @default(uuid())

  itemId      String
  item        Item     @relation(fields: [itemId], references: [id])

  warehouseId String
  warehouse   Warehouse @relation(fields: [warehouseId], references: [id])

  quantity    Decimal  @db.Decimal(18, 4)
  reservedQty Decimal  @default(0) @db.Decimal(18, 4)
  availableQty Decimal @db.Decimal(18, 4)

  avgCost     Decimal  @db.Decimal(18, 4)
  totalValue  Decimal  @db.Decimal(18, 2)

  lastMovement DateTime @default(now())

  @@unique([itemId, warehouseId])
  @@map("bin_cards")
}

// ============================================
// SALES - Invoices & Orders
// ============================================

model Invoice {
  id          String   @id @default(uuid())
  invoiceNumber String
  invoiceDate DateTime
  dueDate     DateTime

  // Type
  invoiceType InvoiceType

  // Party
  customerId  String?
  customer    Customer? @relation(fields: [customerId], references: [id])
  supplierId  String?
  supplier    Supplier? @relation(fields: [supplierId], references: [id])

  // Totals
  subtotal    Decimal  @db.Decimal(18, 2)
  discountAmount Decimal @default(0) @db.Decimal(18, 2)
  taxAmount   Decimal  @default(0) @db.Decimal(18, 2)
  totalAmount Decimal  @db.Decimal(18, 2)
  paidAmount  Decimal  @default(0) @db.Decimal(18, 2)
  balanceDue  Decimal  @db.Decimal(18, 2)

  // Status
  status      InvoiceStatus @default(DRAFT)
  paymentStatus PaymentStatus @default(UNPAID)

  notes       String?
  terms       String?
  incoterm    Incoterm?

  // Three-way matching (PO <-> Receipt <-> Invoice)
  matchStatus String?  @default("UNMATCHED") // UNMATCHED, MATCHED, PARTIAL, MISMATCH
  purchaseOrderId String?
  purchaseOrder   PurchaseOrder? @relation(fields: [purchaseOrderId], references: [id])

  // ZATCA Phase 1 compliance - base64 TLV-encoded QR code
  zatcaQrCode String?

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  companyId   String
  company     Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  createdById String
  createdBy   User     @relation("InvoiceCreatedBy", fields: [createdById], references: [id])

  // Relations
  items       InvoiceItem[]
  payments    Payment[]

  @@unique([companyId, invoiceNumber])

  @@map("invoices")
}

model InvoiceItem {
  id          String   @id @default(uuid())

  itemId      String
  item        Item     @relation(fields: [itemId], references: [id])

  description String?
  quantity    Decimal  @db.Decimal(18, 4)
  unitPrice   Decimal  @db.Decimal(18, 4)
  discountPercent Decimal @default(0) @db.Decimal(5, 2)
  discountAmount  Decimal @default(0) @db.Decimal(18, 2)
  taxRate     Decimal  @default(15) @db.Decimal(5, 2)
  taxAmount   Decimal  @db.Decimal(18, 2)
  totalAmount Decimal  @db.Decimal(18, 2)

  invoiceId   String
  invoice     Invoice  @relation(fields: [invoiceId], references: [id], onDelete: Cascade)

  @@map("invoice_items")
}

enum InvoiceType {
  SALES
  PURCHASE
  CREDIT_NOTE
  DEBIT_NOTE
}

enum InvoiceStatus {
  DRAFT
  SUBMITTED
  PAID
  OVERDUE
  CANCELLED
}

enum PaymentStatus {
  UNPAID
  PARTIAL
  PAID
  OVERPAID
}

// ============================================
// SALES/PURCHASE - Orders
// ============================================

model SalesOrder {
  id          String   @id @default(uuid())
  orderNumber String
  orderDate   DateTime
  deliveryDate DateTime?

  customerId  String
  customer    Customer @relation(fields: [customerId], references: [id])

  subtotal    Decimal  @db.Decimal(18, 2)
  discountAmount Decimal @default(0) @db.Decimal(18, 2)
  taxAmount   Decimal  @default(0) @db.Decimal(18, 2)
  totalAmount Decimal  @db.Decimal(18, 2)

  status      OrderStatus @default(DRAFT)

  notes       String?
  terms       String?
  incoterm    Incoterm?

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  companyId   String
  company     Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  createdById String
  createdBy   User     @relation("SalesOrderCreatedBy", fields: [createdById], references: [id])

  // Relations
  items       OrderItem[]

  @@unique([companyId, orderNumber])

  @@map("sales_orders")
}

model PurchaseOrder {
  id          String   @id @default(uuid())
  orderNumber String
  orderDate   DateTime
  deliveryDate DateTime?

  supplierId  String
  supplier    Supplier @relation(fields: [supplierId], references: [id])

  subtotal    Decimal  @db.Decimal(18, 2)
  discountAmount Decimal @default(0) @db.Decimal(18, 2)
  taxAmount   Decimal  @default(0) @db.Decimal(18, 2)
  totalAmount Decimal  @db.Decimal(18, 2)

  status      OrderStatus @default(DRAFT)

  notes       String?
  terms       String?
  incoterm    Incoterm?

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  companyId   String
  company     Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  createdById String
