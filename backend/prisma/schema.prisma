// ============================================
// MRP (Material Requirements Planning)
// ============================================

enum MRPRunStatus {
  RUNNING
  COMPLETED
  FAILED
}

model MRPRun {
  id          String   @id @default(uuid())
  runDate     DateTime @default(now())
  status      MRPRunStatus @default(RUNNING)
  planningHorizonDays Int  @default(30)
  notes       String?

  companyId   String
  company     Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  runById     String
  runBy       User     @relation(fields: [runById], references: [id])

  exceptions  MRPException[]
  plannedOrders PlannedOrder[]

  createdAt   DateTime @default(now())

  @@index([companyId])
  @@map("mrp_runs")
}

enum MRPExceptionType {
  SHORTAGE
  EXCESS
  REORDER
  OVERDUE
}

model MRPException {
  id          String   @id @default(uuid())
  type        MRPExceptionType
  message     String
  quantity    Decimal  @db.Decimal(18, 4)

  itemId      String
  item        Item     @relation(fields: [itemId], references: [id], onDelete: Cascade)

  mrpRunId    String
  mrpRun      MRPRun   @relation(fields: [mrpRunId], references: [id], onDelete: Cascade)

  createdAt   DateTime @default(now())

  @@map("mrp_exceptions")
}

model PlannedOrder {
  id            String   @id @default(uuid())
  orderType     String   // PURCHASE or PRODUCTION
  quantity      Decimal  @db.Decimal(18, 4)
  suggestedDate DateTime
  status        String   @default("PLANNED") // PLANNED, CONVERTED, CANCELLED

  itemId        String
  item          Item     @relation(fields: [itemId], references: [id], onDelete: Cascade)

  mrpRunId      String
  mrpRun        MRPRun   @relation(fields: [mrpRunId], references: [id], onDelete: Cascade)

  companyId     String
  company       Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)

  createdAt     DateTime @default(now())

  @@index([companyId])
  @@map("planned_orders")
}

