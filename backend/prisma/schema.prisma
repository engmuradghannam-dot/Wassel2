// ALTERNATIVE UNITS OF MEASURE
// ============================================

model UOMConversion {
  id          String   @id @default(uuid())
  uom         String   // e.g. "BOX", "CARTON", "DOZEN"
  conversionFactor Decimal @db.Decimal(18, 6) // how many base UOM units in 1 of this UOM

  itemId      String
  item        Item     @relation(fields: [itemId], references: [id], onDelete: Cascade)

  createdAt   DateTime @default(now())

  @@unique([itemId, uom])
  @@map("uom_conversions")
}

// ============================================
// PRICING PROCEDURE
// ============================================

model PriceList {
  id            String   @id @default(uuid())
  name          String
  currency      String   @default("SAR")
  isDefault     Boolean  @default(false)
  isActive      Boolean  @default(true)
  customerGroup String?
  validFrom     DateTime?
  validTo       DateTime?

  companyId     String
  company       Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)

  items         PriceListItem[]

  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([companyId])
  @@map("price_lists")
}

model PriceListItem {
  id          String   @id @default(uuid())
  price       Decimal  @db.Decimal(18, 4)
  minQty      Decimal  @default(1) @db.Decimal(18, 4)

  itemId      String
  item        Item     @relation(fields: [itemId], references: [id], onDelete: Cascade)

  priceListId String
  priceList   PriceList @relation(fields: [priceListId], references: [id], onDelete: Cascade)

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@unique([priceListId, itemId, minQty])
  @@map("price_list_items")
}

// ============================================
// INCOTERMS
// ============================================

enum Incoterm {
  EXW
  FCA
  FAS
  FOB
  CFR
  CIF
  CPT
  CIP
  DAP
  DPU
  DDP
}

// ============================================
// COST CENTERS
// ============================================

model CostCenter {
  id          String   @id @default(uuid())
  code        String
  name        String
  nameAr      String?
  isGroup     Boolean  @default(false)
  isActive    Boolean  @default(true)

  parentId    String?
  parent      CostCenter? @relation("CostCenterHierarchy", fields: [parentId], references: [id])
  children    CostCenter[] @relation("CostCenterHierarchy")

  companyId   String
  company     Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)

  journalEntryLines JournalEntryLine[]

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@unique([companyId, code])
  @@index([companyId])
  @@map("cost_centers")
}

// ============================================
// AI PREDICTIONS (Sales Forecasting)
// ============================================

model SalesForecast {
  id            String   @id @default(uuid())
  periodStart   DateTime
  periodEnd     DateTime
  method        String   @default("MOVING_AVERAGE") // MOVING_AVERAGE, LINEAR_REGRESSION
  predictedAmount Decimal @db.Decimal(18, 2)
  confidence    Decimal? @db.Decimal(5, 2) // 0-100

  itemId        String?
  item          Item?    @relation(fields: [itemId], references: [id], onDelete: Cascade)

  companyId     String
  company       Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)

  createdAt     DateTime @default(now())

  @@index([companyId])
  @@map("sales_forecasts")
}

// ============================================
// IoT INTEGRATION
// ============================================

enum IoTDeviceStatus {
  ONLINE
  OFFLINE
  MAINTENANCE
}

model IoTDevice {
  id          String   @id @default(uuid())
  deviceCode  String
  deviceType  String   // e.g. "TEMP_SENSOR", "RFID_READER", "WEIGHT_SCALE"
  status      IoTDeviceStatus @default(OFFLINE)
  lastSeenAt  DateTime?

  warehouseId String?
  warehouse   Warehouse? @relation(fields: [warehouseId], references: [id])

  companyId   String
  company     Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)

  readings    IoTReading[]

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@unique([companyId, deviceCode])
  @@index([companyId])
  @@map("iot_devices")
}

model IoTReading {
  id          String   @id @default(uuid())
  metric      String   // e.g. "temperature", "humidity", "weight"
  value       Decimal  @db.Decimal(18, 4)
  unit        String?
  recordedAt  DateTime @default(now())

  deviceId    String
  device      IoTDevice @relation(fields: [deviceId], references: [id], onDelete: Cascade)

  @@index([deviceId])
  @@map("iot_readings")
}
