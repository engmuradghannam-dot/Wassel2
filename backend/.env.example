# MuradERP - Environment Configuration
NODE_ENV=development
PORT=5000

# Database
DATABASE_URL="postgresql://murad_erp:your_password@localhost:5432/murad_erp?schema=public"

# JWT
JWT_SECRET=your_super_secret_jwt_key_change_this_in_production
JWT_EXPIRES_IN=7d
JWT_REFRESH_EXPIRES_IN=30d

# Redis
REDIS_URL=redis://localhost:6379

# Email
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password

# File Upload
UPLOAD_DIR=./uploads
MAX_FILE_SIZE=10485760

# Frontend URL
FRONTEND_URL=http://localhost:3000

# Company Info
COMPANY_NAME=MuradERP
COMPANY_LOGO_URL=

# Email Settings
SMTP_FROM=noreply@wassel.com
SMTP_SECURE=false
