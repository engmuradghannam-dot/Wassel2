{
  "name": "murad-erp-backend",
  "version": "1.0.0",
  "description": "MuradERP - Proprietary Enterprise Resource Planning System",
  "main": "dist/server.js",
  "scripts": {
    "dev": "tsx watch --require dotenv/config src/server.ts",
    "build": "tsc",
    "start": "node dist/server.js",
    "db:generate": "prisma generate",
    "db:migrate": "prisma migrate dev",
    "db:seed": "tsx --require dotenv/config prisma/seeders/seed.ts",
    "db:seed-full": "tsx --require dotenv/config prisma/seeders/seedFull.ts",
    "db:studio": "prisma studio",
    "test": "jest",
    "lint": "eslint src --ext .ts",
    "typecheck": "tsc --noEmit",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "test:ci": "jest --ci --coverage --runInBand"
  },
  "keywords": [
    "erp",
    "business",
    "management"
  ],
  "author": "Murad Ghannam",
  "license": "PROPRIETARY",
  "private": true,
  "dependencies": {
    "@prisma/client": "^5.15.0",
    "apollo-server-express": "^3.13.0",
    "bcryptjs": "^2.4.3",
    "compression": "^1.7.4",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "express-rate-limit": "^7.3.1",
    "graphql": "^16.8.2",
    "helmet": "^7.1.0",
    "ioredis": "^5.4.1",
    "jsonwebtoken": "^9.0.2",
    "morgan": "^1.10.0",
    "multer": "^1.4.5-lts.1",
    "nodemailer": "^6.9.13",
    "qrcode": "^1.5.4",
    "socket.io": "^4.7.5",
    "uuid": "^9.0.1",
    "winston": "^3.13.0",
    "zod": "^3.23.8",
    "pdfkit": "^0.14.0",
    "json2csv": "^6.0.0",
    "swagger-jsdoc": "^6.2.8",
    "swagger-ui-express": "^5.0.0"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/compression": "^1.7.5",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/jest": "^30.0.0",
    "@types/jsonwebtoken": "^9.0.6",
    "@types/morgan": "^1.9.9",
    "@types/multer": "^1.4.11",
    "@types/node": "^20.14.2",
    "@types/qrcode": "^1.5.6",
    "@types/uuid": "^9.0.8",
    "@typescript-eslint/eslint-plugin": "^7.13.0",
    "@typescript-eslint/parser": "^7.13.0",
    "eslint": "^8.57.0",
    "jest": "^29.7.0",
    "prisma": "^5.15.0",
    "ts-jest": "^29.1.4",
    "tsx": "^4.15.2",
    "typescript": "^5.4.5",
    "@types/nodemailer": "^6.4.0",
    "@types/pdfkit": "^0.13.0",
    "@types/json2csv": "^5.0.0",
    "@types/swagger-ui-express": "^4.1.6",
    "supertest": "^7.0.0",
    "@types/supertest": "^6.0.0"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}